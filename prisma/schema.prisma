generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Core: Store & Users ----------
model Store {
  id        String   @id @default(cuid())
  name      String
  address   String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                 User[]
  items                 Item[]
  departments           Department[]
  vendors               Vendor[]
  fuelTanks             FuelTank[]
  fuelPumps             FuelPump[]
  fuelDeliveries        FuelDelivery[]
  fuelReadings          FuelTankReading[]
  inventoryTransactions InventoryTransaction[]
  purchaseOrders        PurchaseOrder[]
  promotions            Promotion[]
  posImportBatches      PosImportBatch[]
  posTransactions       PosTransaction[]
  dailyCloses           DailyClose[]
  spotCountSessions     SpotCountSession[]
}

enum Role {
  OWNER
  MANAGER
  STAFF
}

model User {
  id           String   @id @default(cuid())
  storeId      String
  store        Store    @relation(fields: [storeId], references: [id])
  username     String   @unique
  passwordHash String
  role         Role
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ---------- Catalog & Price Book ----------
model Department {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id])
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items Item[]

  @@unique([storeId, name])
}

model Vendor {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id])
  name      String
  contact   String?
  email     String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items                   Item[]
  purchaseOrders          PurchaseOrder[]
  inventoryReceipts       InventoryTransaction[] @relation("VendorReceipts")
  preferredForInventories Inventory[]            @relation("PreferredVendor")
}

model Item {
  id                String     @id @default(cuid())
  storeId           String
  store             Store      @relation(fields: [storeId], references: [id])
  barcode           String     @unique
  description       String
  departmentId      String
  department        Department @relation(fields: [departmentId], references: [id])
  subCategory       String?
  vendorId          String?
  vendor            Vendor?    @relation(fields: [vendorId], references: [id])
  unitOfMeasure     String     @default("EA")
  packSize          Int?
  cost              Decimal    @db.Decimal(10, 2)
  retailPrice       Decimal    @db.Decimal(10, 2)
  taxable           Boolean    @default(true)
  foodStampEligible Boolean    @default(false)
  fuelItem          Boolean    @default(false)
  status            String     @default("ACTIVE")
  metadata          Json?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  priceHistory          PriceHistory[]
  inventory             Inventory?
  promotionItems        PromotionItem[]
  fuelTanks             FuelTank[]
  inventoryTransactions InventoryTransaction[]
  spotCountLines        SpotCountLine[]
  posTransactions       PosTransaction[]
}

model PriceHistory {
  id        String   @id @default(cuid())
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id])
  field     String
  oldValue  String?
  newValue  String?
  changedBy String
  changedAt DateTime @default(now())
}

// ---------- Inventory ----------
model Inventory {
  id                String   @id @default(cuid())
  itemId            String   @unique
  item              Item     @relation(fields: [itemId], references: [id])
  onHandQty         Decimal  @db.Decimal(10, 2)
  reorderPoint      Decimal  @db.Decimal(10, 2) @default(0)
  preferredVendorId String?
  preferredVendor   Vendor?  @relation("PreferredVendor", fields: [preferredVendorId], references: [id])
  updatedAt         DateTime @updatedAt
}

model InventoryTransaction {
  id              String   @id @default(cuid())
  storeId         String
  store           Store    @relation(fields: [storeId], references: [id])
  itemId          String
  item            Item     @relation(fields: [itemId], references: [id])
  transactionType String
  quantity        Decimal  @db.Decimal(10, 2)
  unitCost        Decimal? @db.Decimal(10, 2)
  referenceNo     String?
  reasonCode      String?
  vendorId        String?
  vendor          Vendor?  @relation("VendorReceipts", fields: [vendorId], references: [id])
  userId          String
  createdAt       DateTime @default(now())
}

model PurchaseOrder {
  id           String   @id @default(cuid())
  storeId      String
  store        Store    @relation(fields: [storeId], references: [id])
  vendorId     String
  vendor       Vendor   @relation(fields: [vendorId], references: [id])
  orderDate    DateTime @default(now())
  status       String   @default("DRAFT")
  items        Json
  exportedPath String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ---------- Fuel (Wet Stock) ----------
model FuelTank {
  id            String   @id @default(cuid())
  storeId       String
  store         Store    @relation(fields: [storeId], references: [id])
  tankNumber    Int
  productGrade  String
  capacity      Decimal  @db.Decimal(10, 2)
  currentVolume Decimal  @db.Decimal(10, 2) @default(0)
  itemId        String?
  item          Item?    @relation(fields: [itemId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  pumps      FuelPump[]
  deliveries FuelDelivery[]
  readings   FuelTankReading[]
}

model FuelPump {
  id           String   @id @default(cuid())
  storeId      String
  store        Store    @relation(fields: [storeId], references: [id])
  pumpNumber   Int
  tankId       String
  tank         FuelTank @relation(fields: [tankId], references: [id])
  meterReading Decimal  @db.Decimal(10, 2) @default(0)
  updatedAt    DateTime @updatedAt
}

model FuelDelivery {
  id            String   @id @default(cuid())
  storeId       String
  store         Store    @relation(fields: [storeId], references: [id])
  tankId        String
  tank          FuelTank @relation(fields: [tankId], references: [id])
  deliveryDate  DateTime
  supplier      String
  bolNumber     String?
  gallons       Decimal  @db.Decimal(10, 2)
  costPerGallon Decimal? @db.Decimal(10, 2)
  userId        String
  createdAt     DateTime @default(now())
}

model FuelTankReading {
  id           String   @id @default(cuid())
  storeId      String
  store        Store    @relation(fields: [storeId], references: [id])
  tankId       String
  tank         FuelTank @relation(fields: [tankId], references: [id])
  readingDate  DateTime @default(now())
  gaugeReading Decimal  @db.Decimal(10, 2)
  temperature  Decimal? @db.Decimal(5, 2)
  userId       String
}

// ---------- Promotions ----------
enum PromotionType {
  FIXED_COMBO
  PERCENT_DISCOUNT
  FIXED_PRICE
}

model Promotion {
  id          String        @id @default(cuid())
  storeId     String
  store       Store         @relation(fields: [storeId], references: [id])
  name        String
  description String?
  type        PromotionType
  value       Decimal       @db.Decimal(10, 2)
  startDate   DateTime
  endDate     DateTime
  timeStart   String?
  timeEnd     String?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  items PromotionItem[]
}

model PromotionItem {
  id          String    @id @default(cuid())
  promotionId String
  promotion   Promotion @relation(fields: [promotionId], references: [id])
  itemId      String
  item        Item      @relation(fields: [itemId], references: [id])
  quantity    Int?
}

// ---------- POS Integration ----------
model PosImportBatch {
  id          String   @id @default(cuid())
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id])
  fileName    String?
  status      String
  totalRows   Int
  processedAt DateTime @default(now())
  errorLog    Json?

  transactions PosTransaction[]
}

model PosTransaction {
  id              String          @id @default(cuid())
  storeId         String
  store           Store           @relation(fields: [storeId], references: [id])
  batchId         String?
  batch           PosImportBatch? @relation(fields: [batchId], references: [id])
  transactionDate DateTime
  itemCode        String
  itemId          String?
  item            Item?           @relation(fields: [itemId], references: [id])
  description     String?
  quantity        Decimal         @db.Decimal(10, 2)
  grossSale       Decimal         @db.Decimal(10, 2)
  discount        Decimal         @db.Decimal(10, 2) @default(0)
  netSale         Decimal         @db.Decimal(10, 2)
  tax             Decimal         @db.Decimal(10, 2) @default(0)
  department      String?
  tenderType      String
  isVoid          Boolean         @default(false)
  isReturn        Boolean         @default(false)
}

// ---------- Daily Reconciliation ----------
model DailyClose {
  id              String    @id @default(cuid())
  storeId         String
  store           Store     @relation(fields: [storeId], references: [id])
  closeDate       DateTime  @unique
  totalSales      Decimal   @db.Decimal(10, 2)
  totalTax        Decimal   @db.Decimal(10, 2)
  cashSales       Decimal   @db.Decimal(10, 2)
  creditSales     Decimal   @db.Decimal(10, 2)
  debitSales      Decimal   @db.Decimal(10, 2)
  ebtSales        Decimal   @db.Decimal(10, 2)
  otherTenders    Decimal   @db.Decimal(10, 2)
  countedCash     Decimal?  @db.Decimal(10, 2)
  bankDeposit     Decimal?  @db.Decimal(10, 2)
  cashVariance    Decimal?  @db.Decimal(10, 2)
  varianceReason  String?
  inventoryShrink Decimal?  @db.Decimal(10, 2)
  fuelVariance    Decimal?  @db.Decimal(10, 2)
  status          String    @default("OPEN")
  reconciledBy    String?
  reconciledAt    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model SpotCountSession {
  id           String   @id @default(cuid())
  storeId      String
  store        Store    @relation(fields: [storeId], references: [id])
  countedAt    DateTime @default(now())
  departmentId String?
  notes        String?
  countedBy    String
  status       String   @default("IN_PROGRESS")

  lines SpotCountLine[]
}

model SpotCountLine {
  id         String           @id @default(cuid())
  sessionId  String
  session    SpotCountSession @relation(fields: [sessionId], references: [id])
  itemId     String
  item       Item             @relation(fields: [itemId], references: [id])
  systemQty  Decimal          @db.Decimal(10, 2)
  countedQty Decimal          @db.Decimal(10, 2)
  variance   Decimal?         @db.Decimal(10, 2)
}
