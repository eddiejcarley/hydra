{
  "name": "Hydra",
  "dockerComposeFile": [
    "docker-compose.yml"
    // GPU users: add "docker-compose.gpu.yml" above to enable CUDA device passthrough
  ],
  "service": "app",
  "workspaceFolder": "/workspaces/hydra",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/rust:1": {
      "version": "latest"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "Prisma.prisma",
        "dsznajder.es7-react-js-snippets",
        "bradlc.vscode-tailwindcss",
        "ms-azuretools.vscode-docker",
        "cweijan.vscode-postgresql-client2",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint",
        "mikestead.dotenv",
        "rangav.vscode-thunder-client"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode"
      }
    }
  },
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y libwebkit2gtk-4.1-dev libappindicator3-dev librsvg2-dev patchelf && npm install && npx prisma generate",
  "forwardPorts": [3000, 5432]
}
